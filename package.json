{
  "name": "any-extractor",
  "version": "2.0.4",
  "description": "A tiny, dependency-light text extractor for PDF, Word, Excel, PowerPoint, OpenDocument and plain-text files.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:check": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "text-extraction",
    "pdf",
    "docx",
    "xlsx",
    "pptx",
    "odt",
    "file-parser"
  ],
  "author": "Pranit Deshmukh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pranit-sh/any-extractor.git"
  },
  "bugs": {
    "url": "https://github.com/pranit-sh/any-extractor/issues"
  },
  "homepage": "https://github.com/pranit-sh/any-extractor#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/pranit.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/concat-stream": "^2.0.3",
    "@types/node": "^22.14.0",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.6",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.8",
    "concat-stream": "^2.0.0",
    "file-type-mime": "^0.4.6",
    "unpdf": "^1.6.2",
    "yauzl": "^3.2.0"
  }
}
