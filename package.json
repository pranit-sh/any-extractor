{
  "name": "any-extractor",
  "version": "3.0.0",
  "description": "Turn any document (PDF, Word, Excel, PowerPoint, OpenDocument, HTML, JSON, CSV, text) into agent-ready markdown, typed blocks, and metadata — one call, with an optional custom-parser hook for vision LLMs and bespoke formats.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "any-extractor-mcp": "dist/mcp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./mcp": {
      "import": "./dist/mcp.mjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:check": "eslint . --no-error-on-unmatched-pattern",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "rag",
    "markdown",
    "structured-extraction",
    "document-parser",
    "text-extraction",
    "vision-llm",
    "ocr",
    "custom-parser",
    "pdf",
    "docx",
    "xlsx",
    "pptx",
    "odt",
    "html",
    "csv",
    "json",
    "file-parser",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Pranit Deshmukh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pranit-sh/any-extractor.git"
  },
  "bugs": {
    "url": "https://github.com/pranit-sh/any-extractor/issues"
  },
  "homepage": "https://github.com/pranit-sh/any-extractor#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/pranit.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.14.0",
    "@types/yauzl": "^2.10.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.6",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.8",
    "file-type-mime": "^0.4.6",
    "unpdf": "^1.6.2",
    "yauzl": "^3.2.0",
    "zod": "^4.4.3"
  }
}
